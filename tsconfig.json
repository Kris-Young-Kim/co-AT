{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@co-at/types": [
        "./packages/types/src/index.ts"
      ],
      "@co-at/types/*": [
        "./packages/types/src/*"
      ],
      "@co-at/lib": [
        "./packages/lib/index.ts"
      ],
      "@co-at/lib/*": [
        "./packages/lib/*"
      ],
      "@co-at/auth": [
        "./packages/auth/index.ts"
      ],
      "@co-at/auth/*": [
        "./packages/auth/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "apps",
    "packages",
    "scripts",
    "tests",
    ".worktrees",
    ".playwright-mcp",
    "actions",
    "app",
    "components",
    "lib",
    "types",
    "proxy.ts"
  ]
}
