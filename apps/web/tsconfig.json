{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@co-at/ui/*": ["../../packages/ui/ui/*"],
      "@/components/ui/*": ["../../packages/ui/ui/*"],
      "@/lib/supabase/*": ["../../packages/lib/supabase/*"],
      "@/lib/validators": ["../../packages/lib/validators.ts"],
      "@/types/*": ["../../packages/lib/types/*"],
      "@/*": ["../../*"],
      "remotion": ["./node_modules/remotion"],
      "remotion/*": ["./node_modules/remotion/*"],
      "@remotion/player": ["./node_modules/@remotion/player"],
      "@remotion/player/*": ["./node_modules/@remotion/player/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
