{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown",
    "compress": true,
    "truncateBase64": true
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": ["repomix-output.md", "repomix-output.xml", "repomix-output.*.md", "repomix-output.*.xml"]
  }
}
